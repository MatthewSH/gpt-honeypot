# Required
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here

# Optional local command testing. Guild commands sync instantly.
GUILD_ID=

# Runtime
DATABASE_PATH=data/gpt-honeypot.sqlite
DEFAULT_ACTION=softban
HONEYPOT_CHANNEL_NAMES=read-me-first,rules-check,verify-here,start-here
TRAP_SLOWMODE_SECONDS=5
DRY_RUN=false
IGNORE_DISCORD_BOTS=true

# Discord can delete up to 7 days of prior messages on ban.
DELETE_MESSAGE_SECONDS=3600

# Built-in dashboard. Put this behind your reverse proxy for production.
DASHBOARD_ENABLED=false
DASHBOARD_TOKEN=change-me
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=3000
