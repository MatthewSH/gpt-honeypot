{
  "name": "gpt-honeypot",
  "version": "0.3.0",
  "description": "A focused multi-channel Discord honeypot bot with analytics, allowlists, and a Bun dashboard.",
  "type": "module",
  "private": false,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "commands:sync": "bun src/sync-commands.ts",
    "check": "tsc --noEmit",
    "build": "bun build src/index.ts --outdir dist --target=bun --format=esm --sourcemap=linked",
    "ci": "bun run check && bun run build"
  },
  "dependencies": {
    "discord.js": "^14.19.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
